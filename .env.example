# ─────────────────────────────────────────────────────────────
# TEXT-TO-SQL CHATBOT — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────


# ─── API KEYS ─────────────────────────────────────────────────
# Fill in the API keys for the providers you want to use.
# You only need at least ONE LLM provider key to run the system.

ANTHROPIC_API_KEY=                    # console.anthropic.com
OPENAI_API_KEY=                       # platform.openai.com
GROQ_API_KEY=                         # console.groq.com (free tier available)
GEMINI_API_KEY=                       # aistudio.google.com (free tier available)


# ─── DATABASE CONNECTIONS ─────────────────────────────────────
# PostgreSQL connection URLs for each database

SALES_DB_URL=postgresql://user@localhost:5432/ecommerce_sales
PRODUCTS_DB_URL=postgresql://user@localhost:5432/ecommerce_products
ANALYTICS_DB_URL=postgresql://user@localhost:5432/ecommerce_analytics


# ─── DEFAULT LLM ──────────────────────────────────────────────
# Fallback LLM used by all agents if per-agent config is not set.
# Provider options: anthropic, openai, groq, gemini

DEFAULT_LLM=openai
DEFAULT_MODEL=gpt-4o


# ─── PER AGENT LLM (optional) ─────────────────────────────────
# Override DEFAULT_LLM for specific agents.
# If not set, agent will use DEFAULT_LLM and DEFAULT_MODEL.
# This allows you to compare different LLMs per agent.

INTENT_CLASSIFIER_LLM=openai
INTENT_CLASSIFIER_MODEL=gpt-4o

RETRIEVAL_EVALUATOR_LLM=openai
RETRIEVAL_EVALUATOR_MODEL=gpt-4o

SQL_GENERATOR_LLM=openai
SQL_GENERATOR_MODEL=gpt-4o

SQL_VALIDATOR_LLM=openai
SQL_VALIDATOR_MODEL=gpt-4o

INSIGHT_GENERATOR_LLM=openai
INSIGHT_GENERATOR_MODEL=gpt-4o


# ─── PIPELINE LLM ─────────────────────────────────────────────
# LLM used for schema enrichment pipeline (enrich_metadata.py)
# Can use cheaper model since this runs only during setup

METADATA_LLM=openai
METADATA_MODEL=gpt-4o-mini


# ─── API & CORS ───────────────────────────────────────────────
# URL used by the Streamlit UI to reach the FastAPI backend.
# In Docker, set this to http://api:8000 (service name in compose network).
API_URL=http://localhost:8000

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# In production, set to your actual frontend URL (e.g. https://yourapp.com).
ALLOWED_ORIGINS=http://localhost:8501

# ─── CHROMADB ─────────────────────────────────────────────────
CHROMA_PATH=./chroma_db

# ─── LOGGING ──────────────────────────────────────────────────
# "text" for human-readable (development), "json" for structured (production)
LOG_FORMAT=text

# ─── RATE LIMITING ────────────────────────────────────────────
# Max requests per minute per IP on the /query endpoint
RATE_LIMIT_PER_MINUTE=30

# ─── QUERY EXECUTOR ───────────────────────────────────────────
QUERY_TIMEOUT_SECONDS=30
QUERY_MAX_ROWS=10000

# ─── DATABASE POOL ────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── SCHEMA RETRIEVER ─────────────────────────────────────────
TOP_K_RETRIEVAL=5
RRF_K=60

# ─── METADATA PIPELINE ────────────────────────────────────────
METADATA_INPUT_FILE=data/metadata.json
METADATA_OUTPUT_FILE=data/schemas/metadata.yaml
METADATA_YAML_FILE=data/schemas/metadata.yaml
